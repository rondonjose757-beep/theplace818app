# ──────────────────────────────────────────────────────
# FRONT CONTROLLER — The Place 818
# Doc root: /home/u510862327/domains/gastroredes.com/
#           public_html/theplace818app/
# ──────────────────────────────────────────────────────

Options -Indexes

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # ── 1. DIRECTORIOS SENSIBLES (403) ───────────────────
  # Bloquea acceso directo a /config/ e /install/
  RewriteRule ^(config|install)(/|$) - [F,L]

  # ── 2. BLOQUEAR PHP EN LA RAÍZ ───────────────────────
  # ^[^/]+\.php$ solo coincide con archivos PHP en la raíz
  # (test.php, setup.php…). NO toca public/index.php ni
  # api/auth/login.php porque esos paths contienen '/'.
  # Sin condición sobre REQUEST_URI: evita dependencia de
  # que esa variable se actualice entre ciclos de rewrite.
  RewriteRule ^[^/]+\.php$ - [F,L]

  # ── 3. API PASA DIRECTO ───────────────────────────────
  # Los endpoints AJAX se sirven tal cual, sin reescritura.
  RewriteRule ^api/ - [L]

  # ── 4. PUBLIC PASA DIRECTO + ANTI-LOOP ───────────────
  # /public/* se sirve tal cual.
  # Esta regla también es la guarda anti-loop ESTRUCTURAL:
  # después de que el catch-all reescriba cualquier ruta a
  # public/index.php, el siguiente ciclo llega aquí y para.
  # No depende de que %{REQUEST_URI} se actualice.
  RewriteRule ^public/ - [L]

  # ── 5. ALIAS LEGACY /assets/ ─────────────────────────
  # Rutas /assets/... sin prefijo /public/ (marcadores,
  # manifest.json, etc.) se mapean a public/assets/
  RewriteRule ^assets/(.*)$ public/assets/$1 [L]

  # ── 6. FRONT CONTROLLER (catch-all) ──────────────────
  # Todo lo demás → public/index.php.
  # Sin condiciones adicionales: la regla ^public/ de arriba
  # garantiza que el segundo ciclo siempre se detiene ahí.
  RewriteRule ^ public/index.php [QSA,L]

</IfModule>

# ── Bloquear .env ──────────────────────────────────────
<Files ".env">
  Order allow,deny
  Deny from all
</Files>

# ── Cabeceras de seguridad ─────────────────────────────
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "DENY"
  Header always set X-XSS-Protection "1; mode=block"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ── Compresión gzip ────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>

# ── Cache para assets estáticos ────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css                  "access plus 1 month"
  ExpiresByType application/javascript    "access plus 1 month"
  ExpiresByType image/png                 "access plus 1 year"
  ExpiresByType image/jpeg                "access plus 1 year"
  ExpiresByType image/svg+xml            "access plus 1 year"
  ExpiresByType application/manifest+json "access plus 1 day"
</IfModule>
