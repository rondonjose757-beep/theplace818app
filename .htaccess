DirectoryIndex public/index.php

Options -Indexes

# ---- Proteger carpetas sensibles ----
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Bloquear acceso directo a /config e /install
  RewriteRule ^config(/|$) - [F,L]
  RewriteRule ^install(/|$) - [F,L]

  # Bloquear ejecución directa de .php fuera de /public/ y /api/
  RewriteCond %{REQUEST_URI} !^/(public|api)/
  RewriteRule \.php$ - [F,L]

  # Pasar /api/ directamente — llamadas AJAX desde el navegador
  RewriteRule ^api/ - [L]

  # Pasar /public/ directamente — assets y vistas PHP
  RewriteRule ^public/ - [L]

  # Redirigir /assets/ a /public/assets/ (rutas legacy sin prefijo /public/)
  RewriteRule ^assets/(.*)$ public/assets/$1 [L]

  # Todo lo demás (incluida /) → front controller
  # Nota: se eliminó !-d para que la raíz "/" no cause 403
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteRule ^ public/index.php [QSA,L]
</IfModule>

# ---- Bloquear acceso al .env ----
<Files ".env">
  Order allow,deny
  Deny from all
</Files>

# ---- Cabeceras de seguridad ----
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "DENY"
  Header always set X-XSS-Protection "1; mode=block"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ---- Compresión gzip ----
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>

# ---- Cache para assets estáticos ----
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css              "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/png             "access plus 1 year"
  ExpiresByType image/jpeg            "access plus 1 year"
  ExpiresByType image/svg+xml        "access plus 1 year"
  ExpiresByType application/manifest+json "access plus 1 day"
</IfModule>
